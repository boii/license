# --- Telegram bot ---
# Buat bot di @BotFather, copy token ke sini.
BOT_TOKEN=123456:ABCDEF...

# Daftar Telegram chat ID yang boleh kelola lisensi (pisah koma).
# Cari ID kamu lewat @userinfobot.
ADMIN_IDS=111111111,222222222

# --- License signing ---
# Random panjang. Dipakai untuk HMAC tanda-tangan respon validasi.
# Generate: openssl rand -hex 32
SIGNING_KEY=changeme-please-generate-a-long-random-secret

# --- API ---
# Optional. Kalau diisi, endpoint admin (/v1/admin/*) butuh header
# X-Admin-Token bernilai sama. Endpoint validate/activate tidak butuh ini.
ADMIN_API_TOKEN=

# Tempat SQLite disimpan (di dalam container). Volume sudah dipetakan ke ./data.
DB_PATH=/srv/data/licenses.db

# Retensi log pemakaian (hari). 0 = simpan selamanya. Default 90.
EVENT_RETENTION_DAYS=90

# Bind
API_HOST=0.0.0.0
API_PORT=8080
