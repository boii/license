# --- Telegram bot ---
# Create a bot via @BotFather and paste the token here.
BOT_TOKEN=123456:ABCDEF...

# Comma-separated list of Telegram chat IDs allowed to manage licenses.
# Find your ID via @userinfobot.
ADMIN_IDS=111111111,222222222

# --- License signing ---
# Long random string. Used as the HMAC key that signs validation responses.
# Generate: openssl rand -hex 32
SIGNING_KEY=changeme-please-generate-a-long-random-secret

# --- API ---
# Optional. If set, admin endpoints (/v1/admin/*) require the X-Admin-Token
# header to match. validate/activate endpoints do not need this.
ADMIN_API_TOKEN=

# Where SQLite is stored (inside the container). The volume is mapped to ./data.
DB_PATH=/srv/data/licenses.db

# Usage log retention in days. 0 = keep forever. Default 90.
EVENT_RETENTION_DAYS=90

# Per-IP rate limit on /v1/* endpoints (requests per minute).
# 0 disables the limit. Default 60.
RATE_LIMIT_PER_MIN=60

# Bind
API_HOST=0.0.0.0
API_PORT=8080
